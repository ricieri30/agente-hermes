# =============================================================
# HERMES AGENT — Configuração
# IMPORTANTE: Não suba este arquivo para o GitHub!
# =============================================================

# Modelo principal — groq é gratuito e rápido
HERMES_MODEL="groq:llama-3.3-70b-versatile"

# ── CHAVES DE API ─────────────────────────────────────────────
# Groq — principal (gratuito, sem cartão)
# ⚠️  REGENERE esta chave em console.groq.com (foi exposta no chat)
GROQ_API_KEY=COLE_SUA_NOVA_CHAVE_GROQ_AQUI

# OpenRouter — fallback (opcional)
OPENROUTER_API_KEY=

# Nous Portal (opcional)
NOUS_API_KEY=

# Gemini — deixar VAZIO para não conflitar
GEMINI_API_KEY=

# Anthropic (opcional)
ANTHROPIC_API_KEY=

# ── TELEGRAM ──────────────────────────────────────────────────
# Token do bot (@BotFather → /newbot)
TELEGRAM_TOKEN=COLE_SEU_TOKEN_DO_BOTFATHER_AQUI

# Seu ID numérico (@userinfobot para descobrir)
TELEGRAM_ALLOWED_USERS=8039948294

# ── DISCORD (opcional) ────────────────────────────────────────
DISCORD_TOKEN=

# ── TIMEOUTS ──────────────────────────────────────────────────
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300
BROWSER_SESSION_TIMEOUT=300
BROWSER_INACTIVITY_TIMEOUT=120

# ── DEBUG — manter false em produção ─────────────────────────
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
MOA_TOOLS_DEBUG=false
