# ================================================================
# HERMES AGENT — Configuração
# ⚠️  Preencha os campos marcados com TODO antes de iniciar
# ================================================================

# Modelo (groq é gratuito e rápido)
HERMES_MODEL="groq:llama-3.3-70b-versatile"

# ── API Keys ────────────────────────────────────────────────────
# TODO: Gere em console.groq.com → API Keys → Create
# Chave válida começa com gsk_ e tem 56 caracteres
GROQ_API_KEY=TODO_COLE_CHAVE_GROQ_56_CHARS

OPENROUTER_API_KEY=
NOUS_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Telegram ────────────────────────────────────────────────────
# TODO: Crie bot no @BotFather → /newbot → copie o token
TELEGRAM_TOKEN=TODO_COLE_TOKEN_DO_BOTFATHER

# Seu ID numérico (confirme em @userinfobot)
TELEGRAM_ALLOWED_USERS=8039948294

# ── Discord (opcional) ──────────────────────────────────────────
DISCORD_TOKEN=

# ── Timeouts ────────────────────────────────────────────────────
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300
BROWSER_SESSION_TIMEOUT=300
BROWSER_INACTIVITY_TIMEOUT=120

# ── Debug ───────────────────────────────────────────────────────
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
MOA_TOOLS_DEBUG=false
